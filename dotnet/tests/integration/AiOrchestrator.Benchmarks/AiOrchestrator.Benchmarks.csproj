<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <AssemblyName>AiOrchestrator.Benchmarks</AssemblyName>
    <RootNamespace>AiOrchestrator.Benchmarks</RootNamespace>
    <OutputType>Exe</OutputType>
    <StartupObject>AiOrchestrator.Benchmarks.BenchmarksProgram</StartupObject>
    <!-- INV-6: Excluded from the standard sln-wide test run; benchmarks are invoked via `bench` target. -->
    <!-- Gate tests in this project still run when this project is targeted explicitly. -->    <IsPackable>false</IsPackable>
    <ServerGarbageCollection>true</ServerGarbageCollection>
    <ConcurrentGarbageCollection>true</ConcurrentGarbageCollection>
    <TieredCompilation>true</TieredCompilation>
    <NoWarn>$(NoWarn);CA1515;CA1812;CA1822;CA1707;CA2007;CA1062;CA1849;CA1031;CA1305;CA1304;CA1311;CA1819;CA5394;CA1054;SA0001;SA1633;SA1413;SA1101;SA1200;SA1309;CS1591</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="BenchmarkDotNet" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
  </ItemGroup><ItemGroup>
    <None Include="baselines\**\*.json" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>


  <ItemGroup>
    <ProjectReference Include="..\..\..\src\core\AiOrchestrator.Abstractions\AiOrchestrator.Abstractions.csproj" />
    <ProjectReference Include="..\..\..\src\core\AiOrchestrator.Models\AiOrchestrator.Models.csproj" />
    <ProjectReference Include="..\..\..\tests\core\AiOrchestrator.TestKit\AiOrchestrator.TestKit.csproj" />
  </ItemGroup>
</Project>
