<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <AssemblyName>AiOrchestrator.Credentials</AssemblyName>
    <RootNamespace>AiOrchestrator.Credentials</RootNamespace>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <!--
      OE0011 suppression — scoped to this project only.
      AiOrchestrator.Credentials owns the UDS / named-pipe IPC endpoint and must call
      System.Net.Sockets and System.IO.Pipes directly to perform per-message
      peer-credential checks (INV-3 / CRED-IPC-2). These are not expressible via IFileSystem.
    -->
    <NoWarn>$(NoWarn);SA1402;SA1201;SA1204;SA1642;IDE0058;CA1716;CA1822;CA1031;CA1849;CA2000;CA1848;CA5350;SA1101;SA1413;SA1116;SA1117;SA1515;CA1303;CA1859;CA2252;CA1812;SA1202;CA1034;SA1649;CA1852;CA1051;IDE0130;SA1600;SA1601;CA1014;CA1062</NoWarn>
  </PropertyGroup><ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="AiOrchestrator.Credentials.Tests" />
  </ItemGroup>

  <ItemGroup>
    <AdditionalFiles Include="PublicAPI.Shipped.txt" />
    <AdditionalFiles Include="PublicAPI.Unshipped.txt" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\core\AiOrchestrator.Abstractions\AiOrchestrator.Abstractions.csproj" />
    <ProjectReference Include="..\..\core\AiOrchestrator.Models\AiOrchestrator.Models.csproj" />
    <ProjectReference Include="..\AiOrchestrator.Audit\AiOrchestrator.Audit.csproj" />
  </ItemGroup>

</Project>
