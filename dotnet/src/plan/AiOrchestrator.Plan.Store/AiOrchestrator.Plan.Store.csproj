    <!--
      OE0011 suppression — scoped to this project only.
      AiOrchestrator.Plan.Store owns the on-disk journal+checkpoint format and performs
      atomic append (write-temp + fsync + rename) directly via System.IO.File because
      IFileSystem does not expose append/fsync/enumerate semantics required here.
    -->
