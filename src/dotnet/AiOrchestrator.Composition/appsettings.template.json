{
  "$schema": "https://json.schemastore.org/appsettings.json",
  "Scheduler": {
    "Channel": {
      "Capacity": 1024,
      "FullMode": "Wait",
      "Dedup": true
    }
  },
  "EventLog": {
    "Reassembly": {
      "MaxBufferBytes": 16777216,
      "TimeoutMs": 5000
    }
  },
  "Plan": {
    "DiskCapMb": 8192
  },
  "Concurrency": {
    "HostFairness": "Proportional",
    "MaxParallelJobsHost": 8,
    "MaxParallelJobsPerUser": 4
  },
  "BuildKeys": {
    "StaleAfterDays": 30,
    "ManifestUrl": "https://aka.ms/aio-build-keys.json"
  },
  "Diagnose": {
    "Pseudonymize": "Anonymous"
  }
}
